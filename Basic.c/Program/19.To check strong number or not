#include<stdio.h>
int main(){
    int n;
    scanf("%d",&n);
    int sum=0;
    int m=n;
    while(n>0){
        int r=n%10;
        int fact=1;
        for(int i=1;i<n;i++){
            fact=fact*i;
        }
        sum=sum+fact;
        n=n/10;
    }
    if(sum==m){
        printf("Strong Number");
    }
    else{
        printf("Not Strong Number");
    }
}
